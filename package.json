{
  "name": "list-config-plugins",
  "version": "1.1.9",
  "description": "Find Expo config plugins in your dependencies and see which ones your app already uses.",
  "author": {
    "name": "WookieFPV (Lukas Müller)",
    "url": "https://github.com/WookieFPV"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WookieFPV/list-config-plugins.git"
  },
  "keywords": [
    "expo",
    "react-native",
    "config-plugin",
    "prebuild",
    "monorepo",
    "cli"
  ],
  "homepage": "https://github.com/WookieFPV/list-config-plugins#readme",
  "bugs": {
    "url": "https://github.com/WookieFPV/list-config-plugins/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "list-config-plugins": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch",
    "updateThirdPartyPlugins": "bun src/thirdPartyPlugins/runUpdateThirdPartyPluginList.ts",
    "lint": "bunx biome check --fix",
    "lint:CI": "bunx biome check",
    "typecheck": "tsc",
    "release": "bun publish --access public",
    "prepublishOnly": "bun i && bun run lint:CI && tsc  && bun run build"
  },
  "dependencies": {
    "@expo/config": "12.0.13",
    "@expo/prebuild-config": "54.0.8",
    "@rnx-kit/tools-workspaces": "0.2.3",
    "@stricli/core": "1.2.5"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@biomejs/biome": "2.4.2",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.9",
    "axios": "1.13.5",
    "lefthook": "2.1.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "zx": "8.8.5"
  }
}
